# ── QuickBite Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.
# NEVER commit .env to version control.

# Flask secret key — used for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET=change_me_to_a_long_random_string

# JWT signing secret — used to sign and verify JWT tokens (generate separately from FLASK_SECRET)
JWT_SECRET=change_me_to_another_long_random_string

# Optional: override database path (default: backend/food_delivery.db)
# DB_PATH=/path/to/food_delivery.db

# Optional: override upload directory (default: backend/uploads/)
# UPLOAD_DIR=/path/to/uploads
