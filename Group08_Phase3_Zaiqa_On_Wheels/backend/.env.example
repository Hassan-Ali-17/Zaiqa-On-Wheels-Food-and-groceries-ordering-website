# ── QuickBite Backend Environment Variables ──────────────────
# Copy this file to .env and fill in real values before running.

# Flask secret key — used for session signing
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change_me_to_a_random_32_char_string

# JWT signing secret — used to sign/verify Bearer tokens
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_another_random_32_char_string

# Flask environment (development | production)
FLASK_ENV=development

# Port to run on (default 5000)
PORT=5000

# Database path (relative to backend/)
DB_PATH=food_delivery.db

# Upload directory for images
UPLOAD_DIR=uploads
