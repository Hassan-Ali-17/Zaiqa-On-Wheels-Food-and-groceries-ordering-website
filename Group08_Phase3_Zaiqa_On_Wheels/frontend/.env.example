# ── QuickBite Frontend Environment Variables ─────────────────
# This is a static HTML/JS frontend — no build step required.
# These values are for documentation purposes.

# Backend API base URL
# If serving frontend FROM Flask (recommended): leave as /api
# If using Live Server / separate server: set to http://localhost:5000
API_BASE_URL=http://127.0.0.1:5000

# NOTE: The API URL is auto-detected in js/shared.js based on
# window.location.port. No manual configuration needed for
# standard development setups.
